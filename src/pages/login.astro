---
import Base from '../layouts/Base.astro';
import { env } from 'cloudflare:workers';
import { getUserByEmail } from '../lib/db';
import { signSession, sessionSetHeader } from '../lib/session';
import bcrypt from 'bcryptjs';

const { tenant, user } = Astro.locals;

// Already logged in
if (user) {
  return Astro.redirect('/', 302);
}

const next = Astro.url.searchParams.get('next') ?? '/';
// Reject open redirects
const safeNext = next.startsWith('/') && !next.startsWith('//') ? next : '/';

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = (form.get('email') as string | null)?.trim().toLowerCase() ?? '';
  const password = (form.get('password') as string | null) ?? '';

  if (email && password) {
    try {
      const db = env.DB;
      const userRow = await getUserByEmail(db, email, tenant.id);
      if (userRow && (await bcrypt.compare(password, userRow.password_hash))) {
        const token = await signSession({ userId: userRow.id, tenantId: tenant.id }, env.SESSION_SECRET);
        return new Response(null, {
          status: 302,
          headers: {
            Location: safeNext,
            'Set-Cookie': sessionSetHeader(token),
          },
        });
      }
      error = 'Invalid email or password.';
    } catch (e) {
      console.error('[login] POST error:', e);
      error = 'Something went wrong. Please try again.';
    }
  } else {
    error = 'Email and password are required.';
  }
}
---
<Base title={`${tenant.name} — Sign in`}>
  <div class="mx-auto max-w-md px-5 py-20 sm:px-8">
    <div class="mb-8 text-center">
      <h1 class="font-serif text-3xl font-normal text-neutral-900">Sign in</h1>
    </div>

    {error && (
      <p class="mb-6 rounded-md bg-red-50 px-4 py-3 text-sm text-red-700">{error}</p>
    )}

    <form method="POST" class="space-y-5">
      <input type="hidden" name="next" value={safeNext} />
      <div>
        <label for="email" class="mb-1.5 block text-xs font-medium uppercase tracking-[0.15em] text-neutral-500">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="w-full border border-neutral-300 bg-white px-4 py-3 text-sm text-neutral-900 outline-none transition focus:border-neutral-900 focus:ring-1 focus:ring-neutral-900"
        />
      </div>
      <div>
        <label for="password" class="mb-1.5 block text-xs font-medium uppercase tracking-[0.15em] text-neutral-500">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          autocomplete="current-password"
          class="w-full border border-neutral-300 bg-white px-4 py-3 text-sm text-neutral-900 outline-none transition focus:border-neutral-900 focus:ring-1 focus:ring-neutral-900"
        />
      </div>
      <button
        type="submit"
        class="mt-2 w-full bg-neutral-900 px-8 py-3.5 text-sm font-semibold uppercase tracking-[0.2em] text-white transition hover:bg-neutral-700"
      >
        Sign in
      </button>
    </form>

    <p class="mt-8 text-center text-sm text-neutral-500">
      Don't have an account?{' '}
      <a href="/register" class="font-medium text-neutral-900 underline underline-offset-2 hover:text-neutral-600">Register</a>
    </p>
  </div>
</Base>
