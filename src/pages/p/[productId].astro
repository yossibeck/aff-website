---
import { getStorySlugByProductId } from '../../lib/db';
import { env } from 'cloudflare:workers';

const { productId } = Astro.params;
const db = env.DB;
const { tenant } = Astro.locals;

if (!productId) return Astro.redirect('/', 302);

let slug: string | null = null;
try {
  slug = await getStorySlugByProductId(db, tenant.id, productId);
} catch {
  return Astro.redirect('/', 302);
}
return Astro.redirect(slug ? `/story/${slug}` : '/', 302);
---
