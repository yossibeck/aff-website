    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.83.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "vitest": "^4.1.4"
  }
}
