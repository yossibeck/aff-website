{
  "name": "aff-website",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "astro build && rm -f .wrangler/deploy/config.json && wrangler deploy --config dist/server/wrangler.json",
    "build-deploy:prod": "npm run deploy",
    "db:refresh": "wrangler d1 export aff-story-db --remote --output local-dev.sql && rm -rf .wrangler/state/v3/d1 && wrangler d1 execute aff-story-db --local --file=local-dev.sql"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.10",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.8",
    "bcryptjs": "^3.0.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.83.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "@types/bcryptjs": "^2.4.6",
    "vitest": "^4.1.4"
  }
}
